/JOB
//NAME TESTSPINDLE
//POS
///NPOS 0,0,0,0,0,0
//INST
///DATE 2025/10/24 14:13
///ATTR SC,RW
///GROUP1 RB1
NOP
'I002 CONTAINS THE RPM SETPOINT.
'SET IT BEFORE CALLING SET SPEED.
SET I002 5000
CALL JOB:SET-SPINDLE
DOUT OT#(2) ON
TIMER T=3.00
SET I002 7500
CALL JOB:SET-SPINDLE
TIMER T=3.00
SET I002 10000
CALL JOB:SET-SPINDLE
TIMER T=3.00
SET I002 7500
CALL JOB:SET-SPINDLE
TIMER T=3.00
SET I002 5000
CALL JOB:SET-SPINDLE
TIMER T=3.00
DOUT OT#(2) OFF
END
